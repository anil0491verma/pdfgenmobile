{
  "name": "itinerary",
  "title": "Tour Itinerary",
  "description": "Generate a beautiful travel itinerary with pre-appended UjjainTravel policies.",
  "version": "1.0",
  "sections": [
    {
      "id": "tour",
      "title": "Tour & Customer Details",
      "icon": "fa-user",
      "fields": [
        { "name": "booking_id", "label": "Booking ID", "type": "text", "required": true, "auto_generate": true },
        { "name": "customer_name", "label": "Customer Name", "type": "text", "required": true, "placeholder": "e.g. Rajesh Kumar" },
        { "name": "customer_phone", "label": "Contact Number", "type": "tel", "required": false },
        { "name": "tour_name", "label": "Tour Title", "type": "text", "required": true, "default": "Ujjain Mahakaleshwar & Omkareshwar Tour" },
        { "name": "start_date", "label": "Journey Start", "type": "date", "required": true, "default": "2026-04-04" },
        { "name": "end_date", "label": "Journey End", "type": "date", "required": true, "default": "2026-04-06" },
        { "name": "num_pax", "label": "Number of Passengers", "type": "text", "required": false, "default": "2 Adults" },
        { "name": "total_amount", "label": "Total Package Amount (Rs)", "type": "text", "required": false, "placeholder": "e.g. 15,500" }

      ]
    },
    {
      "id": "itinerary_text",
      "title": "Itinerary Content",
      "icon": "fa-align-left",
      "fields": [
        { "name": "itinerary_content", "label": "Enter Entire Itinerary Text", "type": "textarea", "required": true, "placeholder": "Day 1: Arrival at Indore...\nDay 2: Mahakaleshwar Darshan..." }
      ]
    }
  ]
}
